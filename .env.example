# Puerto del servidor
PORT=5000

# Clave secreta para firmar tokens JWT (¡cámbiala en producción!)
JWT_SECRET=valhalla_mystic_key_12345

# Orígenes permitidos por CORS (separados por coma)
# En desarrollo: http://localhost:5173
# En producción: https://tu-dominio-frontend.com
CORS_ORIGIN=http://localhost:5173

# Ruta para la persistencia de la base de datos (SQLite) en producción (Docker)
# Ej: DATABASE_PATH=/data/valhalla.sqlite
# DATABASE_PATH=
